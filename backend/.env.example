# ─────────────────────────────────────────────────────────────
#  career-ops — environment variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# Gemini API key — free tier at https://aistudio.google.com/app/apikey
# Free quota: 1500 requests/day, 15 requests/minute
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model — use exactly this string (1.0/1.5 are retired/404)
GEMINI_MODEL=your_model

# ── Optional: future layers ───────────────────────────────────

# Your personal details for auto-apply (Layer 5)
# APPLICANT_NAME=Your Full Name
# APPLICANT_EMAIL=you@email.com
# APPLICANT_PHONE=+91-XXXXXXXXXX
# APPLICANT_LOCATION=Hyderabad, India
# APPLICANT_LINKEDIN=https://linkedin.com/in/yourprofile
# APPLICANT_GITHUB=https://github.com/yourusername

# Proxy (optional — if sites block your IP)
# PROXY_URL=http://user:pass@host:port
